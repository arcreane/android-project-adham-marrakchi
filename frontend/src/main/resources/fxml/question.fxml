<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.quizarena.client.controller.QuestionController"
           styleClass="screen">
    <VBox maxWidth="860" spacing="16" styleClass="card">
        <padding>
            <Insets top="24" right="32" bottom="24" left="32"/>
        </padding>
        <HBox alignment="CENTER_LEFT" spacing="16">
            <Label fx:id="roundLabel" text="Manche —" styleClass="section"/>
            <Label fx:id="categoryLabel" text="" styleClass="subtitle"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="scoreLabel" text="0 pts" styleClass="score"/>
        </HBox>
        <HBox alignment="CENTER_LEFT" spacing="12">
            <ProgressBar fx:id="timeBar" progress="1.0" prefHeight="16" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
            <Label fx:id="timerLabel" text="15,0 s" styleClass="timer"/>
        </HBox>
        <Label fx:id="questionText" text="Chargement de la question…" wrapText="true" styleClass="question"/>
        <ImageView fx:id="questionImage" fitWidth="420" fitHeight="200" preserveRatio="true"/>
        <GridPane hgap="14" vgap="14">
            <columnConstraints>
                <ColumnConstraints percentWidth="50"/>
                <ColumnConstraints percentWidth="50"/>
            </columnConstraints>
            <Button fx:id="choice0" text="…" wrapText="true" maxWidth="Infinity" prefHeight="64"
                    styleClass="choice" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <Button fx:id="choice1" text="…" wrapText="true" maxWidth="Infinity" prefHeight="64"
                    styleClass="choice" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
            <Button fx:id="choice2" text="…" wrapText="true" maxWidth="Infinity" prefHeight="64"
                    styleClass="choice" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <Button fx:id="choice3" text="…" wrapText="true" maxWidth="Infinity" prefHeight="64"
                    styleClass="choice" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
        </GridPane>
        <HBox alignment="CENTER_LEFT">
            <Label fx:id="statusLabel" styleClass="status"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Abandonner" onAction="#onLeave" styleClass="ghost"/>
        </HBox>
    </VBox>
</StackPane>
